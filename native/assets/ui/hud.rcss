body {
    margin: 0dp;
    padding: 0dp;
}

#hud {
    position: absolute;
    right: 10dp;
    top: 10dp;
    text-align: right;
    color: #c8d8e8;
    font-size: 14dp;
    font-family: antonio;
    background-color: rgba(0, 0, 0, 0.45);
    padding: 8dp;
    border-radius: 4dp;
}

#hud div {
    margin-bottom: 2dp;
}
